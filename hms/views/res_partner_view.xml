<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- Form View Inheritance -->

    <record id="view_partner_form_inherit_hms"
            model="ir.ui.view">

        <field name="name">res.partner.form.inherit.hms</field>

        <field name="model">res.partner</field>

        <field name="inherit_id"
               ref="base.view_partner_form"/>

        <field name="arch"
               type="xml">

            <xpath expr="//group[@name='misc']"
                   position="inside">

                <field name="related_patient_id"/>

            </xpath>

        </field>

    </record>


    <!-- Tree/List View Inheritance -->

    <record id="view_partner_tree_inherit_hms"
            model="ir.ui.view">

        <field name="name">res.partner.tree.inherit.hms</field>

        <field name="model">res.partner</field>

        <field name="inherit_id"
               ref="base.view_partner_tree"/>

        <field name="arch"
               type="xml">

            <xpath expr="//list"
                   position="inside">

                <field name="website"/>

            </xpath>

        </field>

    </record>

</odoo>